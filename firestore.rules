rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && request.resource.data.role in ['student', 'teacher'];
    }

    // Notes Rules
    match /notes/{noteId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // In a real app, check for teacher role in token or doc
    }

    // Assignment Rules
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // In a real app, check for teacher role
    }

    // Doubts Rules
    match /doubts/{doubtId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn(); // Allow students to edit their question or teachers to answer
    }

    // Events Rules
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Notifications Rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // System or user can create
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // AI Chat Rules
    match /chats/{chatId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Submission Rules
    match /submissions/{submissionId} {
      allow read: if isSignedIn(); // Simplified for now
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isOwner(resource.data.studentId);
    }
  }
}
