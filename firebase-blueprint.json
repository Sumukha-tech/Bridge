{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a student or teacher in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "department": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Note": {
      "title": "Note",
      "description": "Educational notes uploaded by teachers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "teacherId"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Assignments posted by teachers with deadlines",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "deadline", "teacherId"]
    },
    "Doubt": {
      "title": "Doubt",
      "description": "Questions asked by students to teachers",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "teacherId": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "answered"] },
        "subject": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "teacherId", "question"]
    },
    "Event": {
      "title": "Event",
      "description": "School events students can register for",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "attendees": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user-generated notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "History of AI chats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student assignment submissions",
      "type": "object",
      "properties": {
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "content": { "type": "string" },
        "fileUrl": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assignmentId", "studentId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Shared notes"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Course assignments"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Assignment submissions"
    },
    "/doubts/{doubtId}": {
      "schema": "Doubt",
      "description": "Student doubts and teacher responses"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "School events"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "AI Assistant chat history"
    }
  }
}
